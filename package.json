{
  "name": "aws-tunnel-app",
  "version": "1.0.0",
  "description": "AWS Tunnel Manager - Gerenciador de túneis AWS SSM",
  "homepage": "https://github.com/alexandre-henrique-rp/aws-tunnel-app",
  "main": "dist/main.js",
  "scripts": {
    "start": "npm run build && electron .",
    "build": "npm run build:main && npm run build:renderer",
    "build:main": "tsc",
    "build:renderer": "NODE_ENV=production esbuild src/renderer.ts --bundle --outfile=public/renderer-bundle.js --platform=browser --loader:.tsx=tsx --loader:.ts=ts --external:electron --tree-shaking=true --minify",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder",
    "dist:deb": "npm run build && electron-builder --linux deb",
    "dist:linux": "npm run build && electron-builder --linux"
  },
  "dependencies": {
    "aws-sdk": "^2.1693.0",
    "electron-store": "^11.0.2",
    "jwt-decode": "^4.0.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@types/node": "^25.3.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "electron": "^40.6.1",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.27.3",
    "sharp": "^0.34.5",
    "typescript": "^5.3.0"
  }
}
